<script type="text/javascript">
function googleTranslateElementInit() {
  new google.translate.TranslateElement({pageLanguage: '', includedLanguages: 'ar,zh-CN,en,fr,de,ja,ko,pt,es', layout: google.translate.TranslateElement.InlineLayout.SIMPLE, autoDisplay: false}, 'google_translate_element');
}

function googleTranslateReload() {
    const iframe = document.querySelector('.VIpgJd-ZVi9od-xl07Ob-OEVmcd');
    if (iframe) {
        // unselected languages
        const langLinks = Array.from(
            iframe.contentDocument.body.querySelectorAll('.VIpgJd-ZVi9od-vH1Gmf-ibnC6b'),
        );
        const enLang = langLinks.find((l) => l.value === 'en');
        // selected language link
        const langLink = iframe.contentDocument.body.querySelector('.VIpgJd-ZVi9od-vH1Gmf-ibnC6b-gk6SMd');
        if (enLang && langLink.value !== enLang.value) {
            enLang.dispatchEvent(new Event('click'));
            langLink.dispatchEvent(new Event('click'));
        }
    }
}
</script>
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
