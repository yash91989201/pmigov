<script async type='text/javascript' nonce="">

    var productTracking = function () {
        var productNodes = document.querySelectorAll('[id=productData]');
        var products = [];
        if (productNodes.length) {
            for (var i = 0; i < productNodes.length; i++) {
                var productData = JSON.parse(productNodes[i].innerText.trim());
                var product = {
                    productName: productData.productSku,
                    productCat: productData.productCategory,
                }
                products.push(product)
            }
            var productEvent = {};
            productEvent.detail = {
                event: "prod-view-load",
                eventInfo: "prod-view-load",
                action: "prod-view",
                cart: {
                    product: products,
                }
            };

            var customEventProduct = new CustomEvent('pmi-add-tracking', productEvent);

            document.dispatchEvent(customEventProduct);
        }
    }
    window.addEventListener('DOMContentLoaded', function () {
        productTracking();
    });


</script>

<script async type='text/javascript' nonce="">

    function dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL) {
        var linkClickData = {};
        linkClickData.event = 'linkClick';
        linkClickData.eventInfo = 'linkClick';

        var link = {};
        link.linkTitle = linkTitle;
        link.linkModule = linkModule;
        link.targetURL = targetURL;

        linkClickData.link = link;

        var linkClick = {};

        linkClick.detail = linkClickData;
        var customEvent = new CustomEvent('pmi-add-tracking', linkClick);

        document.dispatchEvent(customEvent);
    }

    function getAdobeRegion(element) {
        var adobeRegion = "";

        var parentElement = element.parentNode;
        if ((parentElement !== null) && (parentElement !== undefined)) {
            while (parentElement.getAttribute("adoberegion") === null) {
                parentElement = parentElement.parentNode;
                if (parentElement.parentNode === null) break;
            }
        }
        if (parentElement.parentNode !== null) {
            adobeRegion = parentElement.getAttribute("adoberegion");
        }

        return adobeRegion;
    }

    //
    // TODO: should update dispatchLinkClickEvent to call dispatchLinkClickEventRawValues
    //
    function dispatchLinkClickEvent(linkItem, adobeRegion) {
        var anchorText = linkItem.innerText.trim();

        var linkClickData = {};
        linkClickData.event = 'linkClick';
        linkClickData.eventInfo = 'linkClick';

        var link = {};
        link.linkTitle = anchorText;
        link.linkModule = adobeRegion;
        link.targetURL = linkItem.getAttribute("href");

        linkClickData.link = link;

        var linkClick = {};

        linkClick.detail = linkClickData;
        var customEvent = new CustomEvent('pmi-add-tracking', linkClick);

        document.dispatchEvent(customEvent);
    }

    function dispatchAnchorLinkClickEvent(element) {
        if (isDataLayerEnabled()) {
            var linkModule = getAdobeRegion(element);
            if ((linkModule !== '') && (linkModule !== undefined)) {
                var linkTitle = element.innerText.trim();
                if (linkTitle == '') {
                    linkTitle = element.getAttribute("title");
                    if (linkTitle == null || linkTitle == '') {
                        var embeddedImage = element.querySelector('img');
                        if (embeddedImage != null) {
                            linkTitle = embeddedImage.getAttribute("alt");
                        }
                    }
                }
                var targetURL = element.getAttribute("href");
                if (targetURL.charAt(0) == '#') {
                    targetURL = window.location.href + targetURL;
                }

                dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL);
            }
        }
    }

    function dispatchAnchorLinkClickEventWithCustomTitle(anchor, itemTitle) {

        var linkModule = getAdobeRegion(anchor);
        if ((linkModule !== '') && (linkModule !== undefined)) {
            var linkTitle = anchor.innerText.trim() + ": " + itemTitle;
            var targetURL = anchor.getAttribute("href");

            dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL);
        }
    }

    function dispatchCTALinkBlockClickTracking(headline, link) {
        const bannerName = headline;
        const bannerCTA = link.getAttribute("title");
        dispatchBannerClickTracking(bannerName, bannerCTA);
    }

    window.addEventListener('DOMContentLoaded', function () {
        const cardFlexWrapper = document.querySelector('.card-flex-wrapper');
        if (cardFlexWrapper !== null) {
            cardFlexWrapper.addEventListener('click', function (event) {
                var links = document.querySelectorAll('.cta-link-block__link');
                var closestParentAnchor = event.target.closest('a');
                for (var link of links) {
                    if (closestParentAnchor === link) {
                        const headline = link.querySelector(".cta-link-block__heading")?.innerText;
                        dispatchCTALinkBlockClickTracking(headline, link);
                        dispatchLinkClickEventRawValues(headline, getAdobeRegion(link), link.href);
                    }
                }
            })
        }
    })

    window.addEventListener('DOMContentLoaded', function () {
        var formLinks = document.querySelectorAll('#form-download');
        for (var link of formLinks) {
            link.addEventListener('click', function doThings(event) { trackDocumentFormDownload(event.target); });
        }
    });

    window.addEventListener('DOMContentLoaded', function () {
        var imageWidgetLinks = document.querySelectorAll('#image-with-caption-link');
        for (var link of imageWidgetLinks) {
            link.addEventListener('click', function doThings(event) { dispatchAnchorLinkClickEvent(event.target.closest('a')) });
        }
    });

    function dispatchContentCardClickTracking(headline, link) {
        const bannerName = headline?.innerText;
        const bannerCTA = link?.innerText;
        dispatchBannerClickTracking(bannerName, bannerCTA);
    }

    window.addEventListener('DOMContentLoaded', function () {
        const carousel = document.querySelector('.carousel');
        if (carousel !== null) {
            carousel.addEventListener('click', function (event) {
                var links = document.querySelectorAll('.content-card a');
                var headlines = document.querySelectorAll('.content-card__heading');
                var i = 0;
                var closestParentAnchor = event.target.closest('a');
                for (var link of links) {
                    if (link === closestParentAnchor) {
                        dispatchContentCardClickTracking(headlines[i], link);
                        dispatchLinkClickEventRawValues(headlines[i]?.innerText, getAdobeRegion(link), link.href);
                    }
                    ++i;
                }
            })
        }
    })

    window.addEventListener('DOMContentLoaded', function () {
        var calendarEventLinks = document.querySelectorAll('ul.list-unstyled.events-search-list li.row.table-list a');
        if (calendarEventLinks.length > 0) {
            var eventList = document.querySelector('ul.list-unstyled.events-search-list');
            if (eventList != undefined) {
                var adobeRegion = eventList.getAttribute("adoberegion");
                for (var i = 0; i < calendarEventLinks.length; i++) {
                    (function (index) {
                        calendarEventLinks[i].addEventListener("click",
                            function (event) {
                                var eventDatailsData = {};
                                eventDatailsData.event = 'search-click';
                                eventDatailsData.eventInfo = 'search-click';

                                var eventDetail = {};

                                eventDetail.detail = eventDatailsData;
                                var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

                                document.dispatchEvent(customEvent);

                                dispatchLinkClickEvent(calendarEventLinks[index], adobeRegion);
                            });
                    })(i);
                }
            }
        }
    });

    var adobeTrackLinkClick = function (selector, regionSelector) {
        var linkItems = document.querySelectorAll(selector);
        for (var i = 0; i < linkItems.length; i++) {
            (function (index) {
                var containingDiv = document.querySelector(regionSelector);
                var adobeRegion = containingDiv.getAttribute("adoberegion");
                linkItems[index].addEventListener("click",
                    function (event) {
                        dispatchLinkClickEvent(linkItems[index], adobeRegion);
                    });
            })(i);
        }
    };

    window.addEventListener('DOMContentLoaded', function () {
        adobeTrackLinkClick('.chapters-near .btn', '.chapters-near');
    });

    //
    // this applies only to the older membership feature list component, not the newer membership comparison component
    //
    window.addEventListener('DOMContentLoaded', function () {
        adobeTrackLinkClick('[adoberegion=membership-feature-list] .btn', '[adoberegion=membership-feature-list]');
    });

    window.addEventListener('DOMContentLoaded', function () {
        adobeTrackLinkClick('[adoberegion=chapter-buttons] .btn', '[adoberegion=chapter-buttons]');
    });

</script>

<script type="text/javascript" nonce="">

    window.addEventListener('load', function () {
        var formName = getFormName();
        var forms = getPageForms();
        for (var i = 0; i < forms.length; i++) {
            var form = forms[i];
            if (isThisASitecoreForm(form) || isThisAnACousticForm(form)) {
                var formType = getFormType(form);
                setFormStartListener(form, formType, formName);
            }

            if (isThisAnACousticForm(form)) {
                setFormCompletedListener(form, formType, formName);
            }
        }
    });

    function dispatchFormInteractionEvent(action, formType, formName, formError) {
        if (isDataLayerEnabled()) {
            var fullFormName = getFullFormName(formType, formName);

            var formData = {};
            formData.event = 'form-interaction';
            formData.eventInfo = 'form-interaction';

            var form = {};
            form.action = action;
            form.formName = fullFormName;
            form.formError = formError;

            formData.form = form;

            var eventDetail = {};

            eventDetail.detail = formData;
            var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

            document.dispatchEvent(customEvent);
        }
    }

    function isDataLayerEnabled() {
        return (typeof (adobeDataLayerAdd) !== 'undefined' && adobeDataLayerAdd !== null);
    }

    function getFormName() {
        var formName = initializeFormName();
        var formNameElement = document.getElementById("form_name");
        if (formNameElement !== null) {
            formName = document.getElementById("form_name").value;
        }

        return formName;
    }

    function getPageForms() {
        return (document.querySelectorAll('form'));
    }

    function initializeFormName() {
        return window.location.pathname.split("/").pop();
    }

    function isThisASitecoreForm(form) {
        if (!form) return false;
        if ((form.id !== null) && (form.id !== undefined) && (form.id.tagName?.toLowerCase() !== 'input')) {
            return (form.id.toLowerCase().startsWith("fxb_"));
        }

        return false;
    }

    function isThisAnACousticForm(form) {
        if ((form.className !== null) && (form.className !== undefined)) {
            return (form.className.toLowerCase().includes("wffm-form"));
        }

        return false;
    }

    function isThisACRMForm(form) {
        return (form.getAttribute("data-template-id") !== null);
    }

    function getFormType(form) {
        if (isThisASitecoreForm(form)) return "sitecore";
        if (isThisAnACousticForm(form)) return "acoustic";
        if (isThisACRMForm(form)) return "crm";

        return "";
    }

    function getFullFormName(formType, formName) {
        var fullFormName = "";
        if (formType !== "") {
            fullFormName = formType + ":";
        }
        fullFormName += formName;

        return fullFormName;
    }

    function getSitecoreFormId(form) {
        return (form.getAttribute("id"));
    }

    function formHasBeenFocused() {
        if (document.getElementById("form_focused") === null) {
            var formFocusedHidden = document.createElement('input');
            formFocusedHidden.setAttribute("type", "hidden");
            formFocusedHidden.setAttribute("id", "form_focused");
            formFocusedHidden.setAttribute("name", "form_focused");
            formFocusedHidden.setAttribute("value", "false");
            document.body.appendChild(formFocusedHidden);
        }
        var formHasBeenFocused = document.getElementById("form_focused").value;

        return (formHasBeenFocused === "true");
    }

    function setFormHasBeenFocused() {
        document.getElementById("form_focused").value = "true";
    }

    function setFormStartListener(form, formType, formName) {
        form.addEventListener("focusin", function (event) {
            if (!formHasBeenFocused()) {
                dispatchFormInteractionEvent("form-start", formType, formName, "");
                setFormHasBeenFocused();
            }
        });
    }

    function setFormCompletedListener(form, formType, formName) {
        //
        // for Sitecore forms, submit handler is in Feature\FormsExtensions\code\Views\FormBuilder\Form.cshtml
        //
        form.addEventListener("submit", function (event) {
            dispatchFormInteractionEvent("form-completed", formType, formName, "");
        });
    }

</script>

<script text="javascript" nonce="">

    function trackDocumentFormDownload(element) {
        if (isDataLayerEnabled()) {
            var form = element.closest('form');
            var dropDownList = form.querySelector("select[id='Download']");
            if (dropDownList === null) {
                dropDownList = form.querySelector("select[id$='book-select']");
            }
            if (dropDownList !== null) {
                dispatchDownloadFormEvent(dropDownList);
                dispatchDownloadFormLinkClickEvent(element, dropDownList);
            } else {
                trackDocumentAnchorDownload(element);
            }
        }
    }

    function dispatchDownloadFormEvent(dropDownList) {
        var fileName = formatDocumentFileNameForTracking(dropDownList.value);
        var language = "";
        var languageElement = Array.from(document.querySelectorAll("input[type='hidden']")).find(function (e) {
            return e.value === dropDownList.options[dropDownList.selectedIndex].text;
        });
        if (languageElement !== null && languageElement !== undefined) {
            language = languageElement.getAttribute("id");
        } else if (dropDownList.options[dropDownList.selectedIndex].text === 'English') {
            language = 'en';
        }

        dispatchDownloadEvent(fileName, language);
    }

    function dispatchDownloadFormLinkClickEvent(element, dropDownList) {
        var linkTitle = element.innerText.trim();
        var linkModule = getAdobeRegion(element);
        var targetURL = new URL(dropDownList.value, document.baseURI).href;

        dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL);
    }

    function trackDocumentAnchorDownload(element) {
        if (isDataLayerEnabled()) {
            dispatchDownloadAnchorEvent(element);
        }
    }

    function dispatchDownloadAnchorEvent(anchor) {
        var href = anchor.getAttribute("href");
        var url = new URL(anchor.getAttribute("href"));
        var params = new URLSearchParams(url.search);

        var fileName = formatDocumentFileNameForTracking(params.get('doc'));
        var language = '';  // not available

        dispatchDownloadEvent(fileName, language);
        dispatchDownloadAnchorLinkClickEvent(anchor);
    }

    function dispatchDownloadEvent(fileName, language) {
        var downloadEvent = {};
        downloadEvent.event = 'downloads';
        downloadEvent.eventInfo = 'downloads';
        downloadEvent.action = "cont-downloads";
        downloadEvent.fileName = fileName;
        downloadEvent.fileLanguage = language;

        var eventDetail = {};

        eventDetail.detail = downloadEvent;
        var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

        document.dispatchEvent(customEvent);
    }

    function dispatchDownloadAnchorLinkClickEvent(anchor) {
        var linkTitle = anchor.innerText.trim();
        var linkModule = getAdobeRegion(anchor);
        var targetURL = anchor.getAttribute("href");

        dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL);
    }

    function formatDocumentFileNameForTracking(fileName) {
        return fileName.split("/").pop();
    }

</script>

<script text="javascript" nonce="">

    function dispatchBannerImpressionTracking(bannerName) {
        if (isDataLayerEnabled()) {
            var bannerData = {};
            bannerData.event = 'bannerimpression';
            bannerData.eventInfo = 'bannerimpression';
            bannerData.action = 'bannerimpression';

            var banner = {};
            banner.bannerName = bannerName;

            bannerData.banner = banner;

            var eventDetail = {};

            eventDetail.detail = bannerData;
            var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

            document.dispatchEvent(customEvent);
        }
    }

    function dispatchBannerClickTracking(bannerName, bannerCTA) {
        var bannerData = {};
        bannerData.event = 'banner';
        bannerData.eventInfo = 'banner';
        bannerData.action = 'banner';

        var banner = {};
        banner.bannerName = bannerName;
        banner.bannerCTA = bannerCTA;

        bannerData.banner = banner;

        var eventDetail = {};

        eventDetail.detail = bannerData;
        var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

        document.dispatchEvent(customEvent);
    }

</script>

<script language="javascript" nonce="">

    var processA_BImpressionTracking = function (testName, experienceName) {
        if (isDataLayerEnabled()) {
            dispatchA_BImpressionTracking(testName, experienceName);
        }
    }

    function dispatchA_BImpressionTracking(testName, experienceName) {
        var abdata = {};
        abdata.event = 'abimpression';
        abdata.eventInfo = 'abimpression';
        abdata.action = 'abimpression';

        var ab = {};
        ab.testName = testName;
        ab.experienceName = experienceName;

        abdata.ab = ab;

        var eventDetail = {};
        eventDetail.detail = abdata;

        var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

        document.dispatchEvent(customEvent);
    }

    function processA_BIClickTracking(testName, experienceName, abCTA) {
        if (isDataLayerEnabled()) {
            dispatchA_BClickTracking(testName, experienceName, abCTA);
        }
    }

    function dispatchA_BClickTracking(testName, experienceName, abCTA) {
        var abdata = {};
        abdata.event = 'abclick';
        abdata.eventInfo = 'abclick';
        abdata.action = 'abclick';

        var ab = {};
        ab.testName = testName;
        ab.experienceName = experienceName;
        ab.abCTA = abCTA;

        abdata.ab = ab;

        var eventDetail = {};
        eventDetail.detail = abdata;

        var customEvent = new CustomEvent('pmi-add-tracking', eventDetail);

        document.dispatchEvent(customEvent);
    }

    function dispatchA_BTestCustomLinkClickTracking(linkTitle, linkModule, targetURL) {
        dispatchLinkClickEventRawValues(linkTitle, linkModule, targetURL);
    }

</script>
