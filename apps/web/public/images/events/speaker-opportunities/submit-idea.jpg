<script nonce="">
    var el = document.getElementById("__PMI_DCP_SCRIPT__");
	el.addEventListener("load", function () {
		// Sizes that are going to be picked up in RequireJS initialisation.
		lazySizes.cfg.rias.widths = [240,600,800,1200,1600,2400,3200];

		// Only for Bootstrap carousel case.#
		// Bug: PMI0009-67
		var carouselImages = document.querySelectorAll(".carousel .carousel-item .iwc-img img");
		var arrayLength = carouselImages.length;
		for (var i = 0; i < arrayLength; i++) {
			carouselImages[i].width = 9999;
			carouselImages[i].height = 9999;
		}

		document.addEventListener("lazybeforeunveil",
			function (e) {
				var target = e.target;
				var bgpos = target.getAttribute("data-bgposition");
				target.style.backgroundPosition = bgpos;
			},
			false);

		document.addEventListener("lazybeforesizes", function (e) {
			var target = e.target;
			target.removeAttribute("width");
			target.removeAttribute("height");
		}, false);

		//Init LazySizes.
		lazySizes.init();
	});
</script>

    
