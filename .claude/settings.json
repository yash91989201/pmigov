{
  "permissions": {
    "allow": [
      "Bash(bun run check*)",
      "Bash(bun run check-types*)",
      "Bash(bun run fix*)",
      "Bash(bun run db:*)",
      "Bash(bun run build*)",
      "Bash(bun run dev*)",
      "Bash(bun install*)",
      "Bash(docker compose *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(openssl rand *)",
      "Bash(cat *)",
      "Bash(bun biome *)",
      "Bash(mkdir -p /private/tmp/claude-501/-Users-ashishpandey-Work-WorkHolo-pmigov/24d4910a-25b6-4573-bdd3-64c50c927998/scratchpad/pmi-screenshots)",
      "Bash(bun add *)",
      "Bash(bunx playwright *)",
      "Bash(node pmi-capture.js)",
      "Bash(bun remove *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo $CLAUDE_TOOL_INPUT | grep -q '\\.env[^.]' && echo 'BLOCKED: Direct .env edits are not allowed. Update packages/env/src/server.ts or web.ts instead, then set the value in apps/web/.env manually.' && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run fix --skip=correctness/noUnusedImports"
          }
        ]
      }
    ]
  }
}
