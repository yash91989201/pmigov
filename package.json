{
  "name": "pmigov",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "db:push": "nx run-many -t db:push --projects=@pmigov/db",
    "db:studio": "nx run-many -t db:studio --projects=@pmigov/db",
    "db:generate": "nx run-many -t db:generate --projects=@pmigov/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@pmigov/db",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@pmigov/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@pmigov/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "latest",
    "nx": "^22.7.5",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}
